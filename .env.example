# Telegram Bot Token (von @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenAI API Key
OPENAI_API_KEY=

# Datenbank (SQLite default, PostgreSQL möglich)
DATABASE_URL=sqlite:///zaehler.db

# Verzeichnisse
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Passwort-Schutz (leer = kein Schutz)
BOT_PASSWORT=
DASHBOARD_USER=admin
DASHBOARD_PASSWORT=

# Bot-Steuerung (false = nur Dashboard starten)
BOT_AKTIV=true

# Dashboard Port
DASHBOARD_PORT=8094
